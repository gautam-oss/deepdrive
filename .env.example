# Copy to .env and fill in values. Never commit .env to source control.
# In production, use AWS Secrets Manager or HashiCorp Vault.
#
# Required values are marked (required). Everything else has a safe default.

# ---------------------------------------------------------------------------
# Django core
# ---------------------------------------------------------------------------
# (required) Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-use-a-long-random-string
DEBUG=True
# Production: include your domains — e.g. yourapp.com,.yourapp.com
ALLOWED_HOSTS=localhost,127.0.0.1,.localhost

# ---------------------------------------------------------------------------
# Database — PostgreSQL (required, no SQLite)
# ---------------------------------------------------------------------------
DB_NAME=healthcare_saas
DB_USER=postgres
# (required)
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# ---------------------------------------------------------------------------
# Redis — Celery broker + result backend
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Email
# Development: console backend prints to stdout — no SMTP needed.
# Production: set EMAIL_BACKEND and fill in all SMTP_* vars below.
# ---------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@yourapp.com
# Required when EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend:
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# ---------------------------------------------------------------------------
# Sentry — leave blank locally, set in production before real patient data
# ---------------------------------------------------------------------------
SENTRY_DSN=

# ---------------------------------------------------------------------------
# Stripe (use test keys locally — set sk_test_placeholder to skip Stripe)
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# ---------------------------------------------------------------------------
# Field-level encryption (required)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: changing this key after first use makes existing PHI unreadable.
# Store in Secrets Manager in production — NOT in this file.
# ---------------------------------------------------------------------------
FIELD_ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# Multi-tenancy — base domain for clinic subdomains
# Clinic "acme" will be accessible at acme.<BASE_DOMAIN>
# ---------------------------------------------------------------------------
BASE_DOMAIN=localhost
