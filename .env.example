# Copy to .env and fill in values. Never commit .env to source control.
# In production, use AWS Secrets Manager or HashiCorp Vault.

# Django
SECRET_KEY=change-me-use-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.localhost

# Database (PostgreSQL — required, no SQLite in this project)
DB_NAME=healthcare_saas
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# Email (SendGrid / AWS SES in production — console backend locally)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@yourapp.com
# SENDGRID_API_KEY=

# Sentry (leave blank locally, set in production before real data)
SENTRY_DSN=

# Stripe (use test keys locally)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Field-level encryption key (django-encrypted-model-fields)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# In production: store in Secrets Manager, NOT here
FIELD_ENCRYPTION_KEY=
